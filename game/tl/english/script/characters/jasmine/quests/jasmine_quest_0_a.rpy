    jasmine "No, I'm just on a break."

# game/script/characters/jasmine/quests/jasmine_quest_0_a.rpy:37
translate english quest_jasmine_questprincipal_0_a_bef3074a:

    # jasmine "¿Qué necesitas?"
    jasmine "What do you need?"

