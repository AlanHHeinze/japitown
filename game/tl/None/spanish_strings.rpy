# Las traducciones al español para strings de Ren'Py están en common.rpym (idioma base None).
# Este archivo contiene traducciones de strings propios del juego.

translate None strings:

    # Slots de guardado
    old "{#file_time}%A, %B %d %Y, %H:%M"
    new "{#file_time}%A, %d de %B de %Y, %H:%M"

    old "empty slot"
    new "Ranura vacía"

    old "Upload Sync"
    new "Subir Sync"

    old "Download Sync"
    new "Bajar Sync"
